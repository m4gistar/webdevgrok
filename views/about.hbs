{{> menu}} {{!-- Include the shared navbar/menu partial at the top of the page --}}

<div class="ui container" style="margin-top: 40px;"> {{!-- Main container for the About page with top margin --}}

  <h1 class="ui header" style="text-align: center;">About SkinB4se</h1> {{!-- Large centered page title --}}

  <div class="ui segment"> {{!-- Boxed section for project statistics --}}
    <h2 class="ui header">Project Statistics</h2> {{!-- Section title for statistics --}}

    <div class="ui three statistics"> {{!-- 3-column statistics component --}}
      <div class="statistic"> {{!-- First statistic block --}}
        <div class="value">{{totalOfficial}}</div> {{!-- Number of official collections passed from routes.js --}}
        <div class="label">Official Collections</div> {{!-- Label for the number --}}
      </div>
      <div class="statistic"> {{!-- Second statistic block --}}
        <div class="value">{{totalPrivate}}</div> {{!-- Number of private collections passed from routes.js --}}
        <div class="label">Private Collections</div> {{!-- Label for the number --}}
      </div>
      <div class="statistic"> {{!-- Third statistic block --}}
        <div class="value">{{totalUsers}}</div> {{!-- Number of registered users passed from routes.js --}}
        <div class="label">Registered Users</div> {{!-- Label for the number --}}
      </div>
    </div>

    <p style="margin-top: 20px; font-size: 1.1em;"> {{!-- Paragraph showing total skins --}}
      Total skins registered in the system: <strong>{{totalSkins}}</strong> {{!-- Bold the total number of skins --}}
    </p>
  </div>

  <div class="ui segment"> {{!-- Second boxed section for project details --}}
    <h3>Project Info</h3> {{!-- Subsection title --}}
    <p>SkinB4se is a full-stack web app built with Node.js, Express, Handlebars. I gave up on Render when it came to file uploads and ideas I wanted to implement...</p> {{!-- Project description --}}
    <p>Author: m4gistar</p> {{!-- Author name --}}

    <!-- Map image section -->
    <h4 style="margin-top: 30px;">CS2 Map Overview</h4> {{!-- heading for map image --}}
    <img src="/uploads/info/map.png" alt="CS2 Map" style="max-width: 100%; border-radius: 8px;"> {{!-- map image --}}

    <!-- Contact form section -->
    <h4 style="margin-top: 40px;">Get In Touch</h4> {{!-- Contact form heading --}}
    <form class="ui form"> {{!-- Simple contact form --}}
      <div class="field"> {{!-- Field for name --}}
        <label>Name</label>
        <input type="text" placeholder="Your name"> {{!-- Name input --}}
      </div>
      <div class="field"> {{!-- Field for email --}}
        <label>Email</label>
        <input type="email" placeholder="your@email.com"> {{!-- Email input --}}
      </div>
      <div class="field"> {{!-- Field for message --}}
        <label>Message</label>
        <textarea placeholder="Your message..."></textarea> {{!-- Message textarea --}}
      </div>
      <button class="ui primary button" type="submit">Send Message</button> {{!-- Submit button --}}
    </form>
  </div>

</div>

{{> footer}} 