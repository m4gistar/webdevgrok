{{> menu}}

<div class="ui container" style="margin-top: 30px;">

  <a href="/dashboard" class="ui button">← Back to Dashboard</a>

  <div class="ui segment">
    <h1 class="ui header">{{collection.name}}</h1>
    <img src="{{collection.image}}" alt="{{collection.name}}" style="max-height: 300px; width: 100%; object-fit: cover; border-radius: 8px;">
    <p><strong>Type:</strong> {{collection.type}}</p>
  </div>

  <h2 class="ui header">Skins ({{collection.items.length}})</h2>

  <button class="ui primary button" onclick="showAddSkinForm({{collection.id}})">
    + Add New Skin
  </button>

  <div class="ui grid" style="margin-top: 20px;">
    {{#each collection.items}}
      <div class="four wide column">
        <div class="ui card">
          <div class="content">
            <!-- Skin Name - Normal Black Text -->
            <div class="header" style="color: black; font-weight: bold;">
              {{gun}} | {{skinname}}
            </div>
            
            <!-- Rarity Label -->
            <div class="meta" style="margin-top: 8px;">
              <span class="ui tiny label rarity-label" 
                    style="font-weight: bold; padding: 6px 12px; color: white;">
                {{rarity}}
              </span>
            </div>
          </div>
          <div class="extra content">
            <button class="ui tiny red button" onclick="deleteSkin({{../collection.id}}, {{id}})">Delete</button>
          </div>
        </div>
      </div>
    {{/each}}
  </div>
</div>

<!-- Add Skin Modal -->
<div id="addSkinModal" class="ui modal">
  <div class="header">Add New Skin to {{collection.name}}</div>
  <div class="content">
    <form id="addSkinForm" action="" method="POST" class="ui form">

      <div class="field">
        <label>Gun</label>
        <select name="gun" required>
          <option value="">Select a Gun...</option>
          {{#each guns.all}}
            <option value="{{this}}">{{this}}</option>
          {{/each}}
        </select>
      </div>

      <div class="field">
        <label>Skin Name</label>
        <input type="text" name="skinname" placeholder="e.g. Panthera onca" required>
      </div>

      <div class="field">
        <label>Rarity</label>
        <select name="rarity" required style="font-weight: bold;">
          <option value="">Select Rarity...</option>
          <option value="Consumer" style="background-color: #d1d5db; color: black;">Consumer</option>
          <option value="Industrial" style="background-color: #94a3b8; color: black;">Industrial</option>
          <option value="Mil-Spec" style="background-color: #3b82f6; color: white;">Mil-Spec</option>
          <option value="Restricted" style="background-color: #a855f7; color: white;">Restricted</option>
          <option value="Classified" style="background-color: #ec4899; color: white;">Classified</option>
          <option value="Covert" style="background-color: #ef4444; color: white;">Covert</option>
        </select>
      </div>
    </form>
  </div>

  <div class="actions">
    <button class="ui button" onclick="hideAddSkinModal()">Cancel</button>
    <button class="ui primary button" onclick="submitAddSkinForm()">Add Skin</button>
  </div>
</div>

<script>
function showAddSkinForm(collectionId) {
  document.getElementById('addSkinForm').action = `/collection/${collectionId}/add-skin`;
  document.getElementById('addSkinModal').classList.add('active');
}

function hideAddSkinModal() {
  document.getElementById('addSkinModal').classList.remove('active');
}

function submitAddSkinForm() {
  document.getElementById('addSkinForm').submit();
}

function deleteSkin(collectionId, skinId) {
  if (confirm("Delete this skin?")) {
    window.location.href = `/collection/${collectionId}/delete-skin/${skinId}`;
  }
}

// Apply rarity colors using JavaScript (no helpers)
document.addEventListener('DOMContentLoaded', function() {
  const labels = document.querySelectorAll('.rarity-label');
  labels.forEach(label => {
    const text = label.textContent.trim();
    if (text === 'Covert') label.style.backgroundColor = '#ef4444';
    else if (text === 'Classified') label.style.backgroundColor = '#ec4899';
    else if (text === 'Restricted') label.style.backgroundColor = '#a855f7';
    else if (text === 'Mil-Spec') label.style.backgroundColor = '#3b82f6';
    else if (text === 'Industrial') label.style.backgroundColor = '#94a3b8';
    else label.style.backgroundColor = '#d1d5db';
  });
});
</script>

{{> footer}}