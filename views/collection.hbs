{{> menu}}

<div class="ui container" style="margin-top: 30px;">

  <a href="/dashboard" class="ui button">← Back to Dashboard</a>

  <div class="ui segment">
    <h1 class="ui header">{{collection.name}}</h1>
    <img src="{{collection.image}}" alt="{{collection.name}}" style="max-height: 300px; width: 100%; object-fit: cover; border-radius: 8px;">
    <p><strong>Type:</strong> {{collection.type}}</p>
  </div>

  <h2 class="ui header">Skins ({{collection.items.length}})</h2>

  {{#if isOwner}}
    <button class="ui primary button" onclick="showAddSkinForm({{collection.id}})">
      + Add New Skin
    </button>
  {{/if}}

  <div class="ui grid" style="margin-top: 20px;">
    {{#each collection.items}}
      <div class="four wide column">
        <div class="ui card">
          <div class="content">
            <div class="header" style="color: black;">
              {{gun}} | {{skinname}}
            </div>
            <div class="meta">
              <span class="ui tiny label" style="background-color: {{getRarityColor rarity}}; color: white;">
                {{rarity}}
              </span>
            </div>
          </div>
          <div class="extra content">
            {{#if ../isOwner}}
              <button class="ui tiny red button" onclick="deleteSkin({{../collection.id}}, {{id}})">Delete Skin</button>
            {{/if}}
          </div>
        </div>
      </div>
    {{/each}}
  </div>

  {{#if isOwner}}
    <button class="ui red button" onclick="deleteCollection({{collection.id}})" style="margin-top: 30px;">
      🗑 Delete Entire Collection
    </button>
  {{/if}}

</div>

<!-- Add Skin Modal -->
{{#if isOwner}}
<div class="ui modal" id="addSkinModal">
  <div class="header">Add New Skin</div>
  <div class="content">
    <form id="addSkinForm" action="/collection/{{collection.id}}/add-skin" method="POST" class="ui form">
      <div class="field">
        <label>Gun</label>
        <select name="gun" required>
          <option value="">Select Gun...</option>
          <optgroup label="Pistols">{{#each guns.pistols}}<option value="{{this}}">{{this}}</option>{{/each}}</optgroup>
          <optgroup label="Rifles">{{#each guns.rifles}}<option value="{{this}}">{{this}}</option>{{/each}}</optgroup>
          <optgroup label="Snipers">{{#each guns.snipers}}<option value="{{this}}">{{this}}</option>{{/each}}</optgroup>
          <optgroup label="SMGs">{{#each guns.smgs}}<option value="{{this}}">{{this}}</option>{{/each}}</optgroup>
          <optgroup label="Heavy">{{#each guns.heavy}}<option value="{{this}}">{{this}}</option>{{/each}}</optgroup>
        </select>
      </div>
      <div class="field">
        <label>Skin Name</label>
        <input type="text" name="skinname" placeholder="Skin name" required>
      </div>
      <div class="field">
        <label>Rarity</label>
        <select name="rarity" required>
          <option value="Consumer">Consumer</option>
          <option value="Industrial">Industrial</option>
          <option value="Mil-Spec">Mil-Spec</option>
          <option value="Restricted">Restricted</option>
          <option value="Classified">Classified</option>
          <option value="Covert">Covert</option>
        </select>
      </div>
    </form>
  </div>
  <div class="actions">
    <button class="ui button" onclick="hideAddSkinModal()">Cancel</button>
    <button class="ui primary button" onclick="submitAddSkinForm()">Add Skin</button>
  </div>
</div>
{{/if}}

<script>
function showAddSkinForm(collectionId) {
  document.getElementById('addSkinForm').action = `/collection/${collectionId}/add-skin`;
  document.getElementById('addSkinModal').classList.add('active');
}

function hideAddSkinModal() {
  document.getElementById('addSkinModal').classList.remove('active');
}

function submitAddSkinForm() {
  document.getElementById('addSkinForm').submit();
}

function deleteSkin(collectionId, skinId) {
  if (confirm("Delete this skin?")) {
    window.location.href = `/collection/${collectionId}/delete-skin/${skinId}`;
  }
}

function deleteCollection(collectionId) {
  if (confirm("Delete the entire collection?")) {
    window.location.href = `/collection/${collectionId}/delete`;
  }
}
</script>

{{> footer}}