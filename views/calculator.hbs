{{> menu}}

<div class="ui container" style="margin-top: 30px;">
  <h1 class="ui header">Tradeup Calculator</h1>
  <p>Select exactly 10 skins of the same rarity</p>

  <div class="ui grid">
    <!-- Left: Search -->
    <div class="eight wide column">
      <div class="ui fluid input">
        <input type="text" id="skinSearch" placeholder="Search skins..." onkeyup="filterSkins()">
      </div>
      <div id="skinList" class="ui segment" style="max-height: 650px; overflow-y: auto; margin-top: 10px;">
      </div>
    </div>

    <!-- Right: 10 Slots -->
    <div class="eight wide column">
      <h3 class="ui header">Selected Skins ({{selectedSkins.length}}/10)</h3>
      <div id="slots" class="ui grid" style="min-height: 420px;"></div>

      <div id="tradeupResults" style="display: none; margin-top: 30px;">
        <h3 id="rarityHeader" class="ui header"></h3>
        <div id="outcomesList" class="ui divided list"></div>
      </div>
    </div>
  </div>
</div>

<script>
// Global variables
let allSkins = [];
let selectedSkins = [];
let currentRarityFilter = null;

// Load all skins
function loadAllSkins() {
  allSkins = [];
  const collectionsData = {{{JSONstringify collections}}};

  collectionsData.forEach(collection => {
    if (collection.items) {
      collection.items.forEach(skin => {
        allSkins.push({
          id: skin.id,
          gun: skin.gun,
          skinname: skin.skinname,
          rarity: skin.rarity,
          collectionName: collection.name
        });
      });
    }
  });

  console.log("✅ Loaded", allSkins.length, "skins");
}

function getRarityHex(rarity) {
  const colors = {
    "Consumer": "#d1d5db", "Industrial": "#94a3b8", "Mil-Spec": "#3b82f6",
    "Restricted": "#a855f7", "Classified": "#ec4899", "Covert": "#ef4444"
  };
  return colors[rarity] || "#888888";
}

function getNextRarity(rarity) {
  const map = {
    "Consumer": "Industrial",
    "Industrial": "Mil-Spec",
    "Mil-Spec": "Restricted",
    "Restricted": "Classified",
    "Classified": "Covert"
  };
  return map[rarity] || null;
}

// Render skins on left
function renderSkinList(filtered) {
  const container = document.getElementById('skinList');
  container.innerHTML = '';

  if (filtered.length === 0) {
    container.innerHTML = '<p>No matching skins found.</p>';
    return;
  }

  filtered.forEach(skin => {
    const div = document.createElement('div');
    div.className = 'ui segment';
    div.style.cursor = 'pointer';
    div.style.marginBottom = '6px';
    div.innerHTML = `
      <strong>${skin.gun}</strong> | ${skin.skinname}
      <span class="ui tiny label" style="float:right; background-color: ${getRarityHex(skin.rarity)}; color: white;">
        ${skin.rarity}
      </span>
    `;
    div.onclick = () => addToTradeup(skin);
    container.appendChild(div);
  });
}

function addToTradeup(skin) {
  if (selectedSkins.length >= 10) return;
  if (selectedSkins.length > 0 && skin.rarity !== currentRarityFilter) {
    alert("All 10 skins must be the same rarity!");
    return;
  }
  currentRarityFilter = skin.rarity;
  selectedSkins.push(skin);
  renderSlots();
  filterSkins();
}

function removeFromSlot(index) {
  selectedSkins.splice(index, 1);
  if (selectedSkins.length === 0) currentRarityFilter = null;
  renderSlots();
  filterSkins();
}

function renderSlots() {
  const container = document.getElementById('slots');
  container.innerHTML = '';

  for (let i = 0; i < 10; i++) {
    const slot = document.createElement('div');
    slot.className = 'four wide column';
    slot.style.minHeight = '85px';
    slot.style.border = '2px dashed #ccc';
    slot.style.borderRadius = '8px';
    slot.style.display = 'flex';
    slot.style.alignItems = 'center';
    slot.style.justifyContent = 'center';
    slot.style.marginBottom = '10px';
    slot.style.cursor = 'pointer';

    if (selectedSkins[i]) {
      const s = selectedSkins[i];
      slot.innerHTML = `
        <div style="text-align:center;">
          <strong>${s.gun}</strong><br>
          <small>${s.skinname}</small>
        </div>
      `;
      slot.onclick = () => removeFromSlot(i);
    } else {
      slot.innerHTML = `<span style="color:#aaa;">Slot ${i+1}</span>`;
    }
    container.appendChild(slot);
  }

  if (selectedSkins.length === 10) {
    calculateTradeupOutcomes();
  } else {
    document.getElementById('tradeupResults').style.display = 'none';
  }
}

function calculateTradeupOutcomes() {
  const resultsContainer = document.getElementById('tradeupResults');
  const header = document.getElementById('rarityHeader');
  const list = document.getElementById('outcomesList');

  resultsContainer.style.display = 'block';
  header.textContent = `Possible ${getNextRarity(currentRarityFilter)} Outcomes`;

  // Group selected skins by collection
  const collectionCounts = {};
  selectedSkins.forEach(skin => {
    collectionCounts[skin.collectionName] = (collectionCounts[skin.collectionName] || 0) + 1;
  });

  list.innerHTML = '';

  // For each collection that has skins selected
  Object.keys(collectionCounts).forEach(collectionName => {
    const count = collectionCounts[collectionName];
    const weight = count / 10; // A

    // Find all possible higher-rarity skins in this collection
    const possibleOutcomes = allSkins.filter(s => 
      s.collectionName === collectionName && 
      s.rarity === getNextRarity(currentRarityFilter)
    );

    if (possibleOutcomes.length > 0) {
      const chancePerSkin = Math.round(100 / possibleOutcomes.length); // B

      possibleOutcomes.forEach(outcome => {
        const finalChance = Math.round(weight * chancePerSkin);

        const item = document.createElement('div');
        item.className = 'item';
        item.innerHTML = `
          <div class="content">
            <div class="header">${outcome.gun} | ${outcome.skinname}</div>
            <div class="description">${finalChance}% chance</div>
          </div>
        `;
        list.appendChild(item);
      });
    }
  });
}

function filterSkins() {
  const searchTerm = document.getElementById('skinSearch').value.toLowerCase().trim();
  let filtered = allSkins;

  if (currentRarityFilter) filtered = filtered.filter(s => s.rarity === currentRarityFilter);
  if (searchTerm) {
    filtered = filtered.filter(s => 
      s.gun.toLowerCase().includes(searchTerm) || 
      s.skinname.toLowerCase().includes(searchTerm)
    );
  }

  renderSkinList(filtered);
}

// Initialize
document.addEventListener('DOMContentLoaded', () => {
  loadAllSkins();
  filterSkins();
  renderSlots();
});
</script>

{{> footer}}