{{> menu}}

<div class="ui container" style="margin-top: 30px;">
  <h1 class="ui header">Tradeup Calculator</h1>
  <p>Select exactly 10 skins of the same rarity to simulate a trade-up</p>

  <div class="ui grid">
    <!-- Left: Search -->
    <div class="eight wide column">
      <div class="ui fluid input">
        <input type="text" id="skinSearch" placeholder="Search skins..." onkeyup="filterSkins()">
      </div>
      <div id="skinList" class="ui segment" style="max-height: 650px; overflow-y: auto; margin-top: 10px;">
        <!-- Populated by JS -->
      </div>
    </div>

    <!-- Right: Slots + Results -->
    <div class="eight wide column">
      <h3 class="ui header">Selected Skins ({{selectedSkins.length}}/10)</h3>
      <div id="slots" class="ui grid" style="min-height: 420px;"></div>

      <div id="tradeupResults" style="display: none; margin-top: 30px;">
        <h3 id="rarityHeader" class="ui header"></h3>
        <div id="outcomesList" class="ui divided list"></div>
      </div>
    </div>
  </div>
</div>

<script>
// Global variables
let allSkins = [];
let selectedSkins = [];
let currentRarityFilter = null;

// Load all skins
function loadAllSkins() {
  allSkins = [];
  {{#each collections}}
    {{#each items}}
      allSkins.push({
        id: {{id}},
        gun: "{{gun}}",
        skinname: "{{skinname}}",
        rarity: "{{rarity}}",
        collectionName: "{{../name}}"
      });
    {{/each}}
  {{/each}}
}

function getNextRarity(rarity) {
  const map = { "Consumer": "Industrial", "Industrial": "Mil-Spec", "Mil-Spec": "Restricted", "Restricted": "Classified", "Classified": "Covert" };
  return map[rarity] || null;
}

function getRarityHex(rarity) {
  const colors = { "Consumer":"#d1d5db", "Industrial":"#94a3b8", "Mil-Spec":"#3b82f6", "Restricted":"#a855f7", "Classified":"#ec4899", "Covert":"#ef4444" };
  return colors[rarity] || "#888888";
}

// Render left side
function renderSkinList(filtered) {
  const container = document.getElementById('skinList');
  container.innerHTML = '';

  filtered.forEach(skin => {
    const div = document.createElement('div');
    div.className = 'ui segment';
    div.style.cursor = 'pointer';
    div.style.marginBottom = '6px';
    div.innerHTML = `
      <strong>${skin.gun}</strong> | ${skin.skinname}
      <span class="ui tiny label" style="float:right; background-color: ${getRarityHex(skin.rarity)}; color: white;">
        ${skin.rarity}
      </span>
    `;
    div.onclick = () => addToTradeup(skin);
    container.appendChild(div);
  });
}

// Add to slots
function addToTradeup(skin) {
  if (selectedSkins.length >= 10) return;
  if (selectedSkins.length > 0 && skin.rarity !== currentRarityFilter) {
    alert("All 10 skins must be the same rarity!");
    return;
  }
  currentRarityFilter = skin.rarity;
  selectedSkins.push(skin);
  renderSlots();
  filterSkins();
}

function removeFromSlot(index) {
  selectedSkins.splice(index, 1);
  if (selectedSkins.length === 0) currentRarityFilter = null;
  renderSlots();
  filterSkins();
}

function renderSlots() {
  const container = document.getElementById('slots');
  container.innerHTML = '';

  for (let i = 0; i < 10; i++) {
    const slot = document.createElement('div');
    slot.className = 'four wide column';
    slot.style.minHeight = '85px';
    slot.style.border = '2px dashed #ccc';
    slot.style.borderRadius = '8px';
    slot.style.display = 'flex';
    slot.style.alignItems = 'center';
    slot.style.justifyContent = 'center';
    slot.style.marginBottom = '10px';
    slot.style.cursor = 'pointer';

    if (selectedSkins[i]) {
      const s = selectedSkins[i];
      slot.innerHTML = `
        <div style="text-align:center; width:100%;">
          <strong>${s.gun}</strong><br>
          <small>${s.skinname}</small><br>
          <span class="ui tiny label" style="background-color: ${getRarityHex(s.rarity)}; color:white;">${s.rarity}</span>
        </div>
      `;
      slot.onclick = () => removeFromSlot(i);
    } else {
      slot.innerHTML = `<span style="color:#aaa;">Slot ${i+1}</span>`;
    }
    container.appendChild(slot);
  }

  if (selectedSkins.length === 10) calculateTradeupOutcomes();
  else document.getElementById('tradeupResults').style.display = 'none';
}

// Correct Tradeup Logic
function calculateTradeupOutcomes() {
  const resultsDiv = document.getElementById('tradeupResults');
  const listDiv = document.getElementById('outcomesList');
  const header = document.getElementById('rarityHeader');

  const inputRarity = currentRarityFilter;
  const nextRarity = getNextRarity(inputRarity);

  // Special message for Covert → Exceptionally Rare
  if (inputRarity === "Covert") {
    header.innerHTML = `<strong>Trades up to two different Exceptionally Rare Items</strong>`;
    listDiv.innerHTML = `<div class="item">Exceptionally Rare items are extremely rare and valuable.</div>`;
    resultsDiv.style.display = 'block';
    return;
  }

  header.innerHTML = `Possible <strong>${nextRarity}</strong> Outcomes`;

  // Count skins per collection
  const collectionCount = {};
  selectedSkins.forEach(s => {
    collectionCount[s.collectionName] = (collectionCount[s.collectionName] || 0) + 1;
  });

  listDiv.innerHTML = '';

  Object.keys(collectionCount).forEach(collectionName => {
    const inputCount = collectionCount[collectionName];
    const A = inputCount / 10;

    const possibleSkins = allSkins.filter(s => 
      s.collectionName === collectionName && s.rarity === nextRarity
    );

    const B = possibleSkins.length > 0 ? 100 / possibleSkins.length : 0;

    possibleSkins.forEach(skin => {
      const chance = Math.round(A * B);

      const item = document.createElement('div');
      item.className = 'item';
      item.innerHTML = `
        <strong>${skin.gun} | ${skin.skinname}</strong>
        <span style="float:right; color:#ef4444; font-weight:bold;">${chance}%</span>
      `;
      listDiv.appendChild(item);
    });
  });

  resultsDiv.style.display = 'block';
}

function filterSkins() {
  const searchTerm = document.getElementById('skinSearch').value.toLowerCase().trim();
  let filtered = allSkins;

  if (currentRarityFilter) filtered = filtered.filter(s => s.rarity === currentRarityFilter);
  if (searchTerm) {
    filtered = filtered.filter(s => 
      s.gun.toLowerCase().includes(searchTerm) || s.skinname.toLowerCase().includes(searchTerm)
    );
  }

  renderSkinList(filtered);
}

// Initialize
document.addEventListener('DOMContentLoaded', () => {
  loadAllSkins();
  filterSkins();
  renderSlots();
});
</script>

{{> footer}}